# JARVIS — Environment variables (copy this to `.env` and fill in as needed)
# Precedence: CLI flags > ENV (.env) > config.yaml defaults
# Do NOT commit your `.env` file.

# Provider selection: local | openai | benchmark
JARVIS_PROVIDER=local

# OpenAI (only needed for provider=openai or benchmark)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local model (alias/name you’ll pick later)
LOCAL_MODEL_NAME=

# Outputs: root folder and timestamped subfolders
JARVIS_OUTPUT_ROOT=OUTPUTS
JARVIS_OUTPUT_TIMESTAMP=true
JARVIS_OUTPUT_TS_FORMAT=%Y%m%d_%H%M%S

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
JARVIS_LOG_LEVEL=INFO

# Paths
JARVIS_PROMPTS_DIR=prompts
JARVIS_SAMPLES_DIR=samples

# Ollama base URL (shared by inference and embedding)
OLLAMA_BASE_URL=http://localhost:11434

# Memory / embedding
EMBEDDING_MODEL=qwen3-embedding
JARVIS_DB_PATH=data/jarvis.db

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# User identity — your name, used by JARVIS to understand who "the user" refers to
JARVIS_USER_NAME=
